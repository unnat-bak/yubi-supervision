# YUBI Supervision — environment template
# Copy to .env and adjust as needed: cp .env.example .env

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false

# Webcam (server-side OpenCV capture)
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_TIMEOUT_SEC=12
# Default input source (the UI source box overrides this per-session).
# Leave blank for the webcam. Accepts:
#   - a webcam index            CAMERA_SOURCE=0
#   - a local video file        CAMERA_SOURCE=clips/traffic.mp4
#   - an RTSP / HTTP CCTV feed  CAMERA_SOURCE=rtsp://user:pass@10.0.0.5:554/stream1
#   - a YouTube URL (yt-dlp)    CAMERA_SOURCE=https://youtu.be/XXXXXXXXXXX
# CAMERA_SOURCE=
# Loop file/clip sources when they reach the end (continuous analysis feed).
SOURCE_LOOP=true
# yt-dlp format selector used when resolving a YouTube/stream URL.
# YOUTUBE_FORMAT=best[ext=mp4][height<=1080]/best[height<=1080]/best

# Object detection
# yolov8n.pt = fastest, yolov8s.pt = better accuracy (default), yolov8m.pt = best/slowest
# Use a *-seg model (e.g. yolov8s-seg.pt) to enable the Masks layer (segmentation).
YOLO_MODEL=yolov8s.pt
YOLO_IMGSZ=640
YOLO_IOU=0.5
YOLO_MAX_DET=30
# Run YOLO every N frames (1 = every frame; higher = more FPS, slightly laggier boxes)
YOLO_STRIDE=2
DEFAULT_CONFIDENCE=0.35

# Inference downscale (1080p webcams often ignore CAMERA_WIDTH/HEIGHT — this caps processing size)
PROCESSING_MAX_WIDTH=1280
STREAM_JPEG_QUALITY=80

# Alerts (optional): comma-separated COCO labels + webhook
# ALERT_CLASSES=person,cell phone
# ALERT_WEBHOOK_URL=https://example.com/hook
ALERT_COOLDOWN_SEC=10

# Optional: override MediaPipe model directory
# MODELS_DIR=backend/models

# YUBI v3.0 intelligence layer (user-facing name; env prefix GEMINI_*)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_ENABLED=true
GEMINI_MODEL=gemini-2.5-flash
GEMINI_INTERVAL_SEC=3
GEMINI_MAX_OBJECTS=8
GEMINI_ANALYSIS_SCALE=0.6
# Optional cap (0 = scale only)
GEMINI_ANALYSIS_MAX_WIDTH=0
GEMINI_JPEG_QUALITY=70
GEMINI_BOX_MAX_AGE_SEC=6
# Below this local confidence, v3.0 verifies or corrects the label (or suppresses noise).
GEMINI_VERIFY_BELOW=0.45
# How long a v3.0-confirmed label persists on a tracker without another API call.
GEMINI_LABEL_CACHE_SEC=45
# YUBI v3.0 passes when generating the post-session markdown report (1–3).
SESSION_REPORT_PASSES=3

# Identity layer (YUBI v3.0 vision) — name / jersey number / descriptor per
# tracked person. Requires GEMINI_API_KEY. Toggle live via the "Identity" chip.
IDENTITY_ENABLED=true
IDENTITY_INTERVAL_SEC=4
IDENTITY_MAX_PERSONS=6
# How long a confirmed identity sticks on a tracker without re-querying.
IDENTITY_LABEL_CACHE_SEC=90

# Initial overlay layers (the UI can toggle these live once running).
SHOW_MASKS_DEFAULT=false
SHOW_POSE_LABELS_DEFAULT=false
SHOW_IDENTITY_DEFAULT=false
