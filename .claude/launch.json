{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "YUBI Supervision (dev, hot-reload)",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["backend.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "YUBI Supervision (prod)",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["backend.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    }
  ]
}
